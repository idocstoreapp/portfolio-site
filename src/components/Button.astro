---
export interface Props {
  href: string;
  variant?: 'primary' | 'ghost';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const getPadding = (size: string) => {
  const paddings = {
    sm: '8px 16px',
    md: '12px 32px',
    lg: '16px 48px',
    xl: '10px 30px'
  };
  return paddings[size as keyof typeof paddings] || paddings.md;
};

const getFontSize = (size: string) => {
  const sizes = {
    sm: '14px',
    md: '16px',
    lg: '18px',
    xl: '22px'
  };
  return sizes[size as keyof typeof sizes] || sizes.md;
};

const padding = getPadding(size);
const fontSize = getFontSize(size);
---

<a 
  href={href}
  style={`
    padding: ${padding};
    font-size: ${fontSize};
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-weight: bold;
    border-radius: 8px;
    text-decoration: none;
    transition: all 200ms ease;
    line-height: 1.3;
    cursor: pointer;
    ${variant === 'primary' 
      ? `background: linear-gradient(135deg, #22d3ee, #3b82f6); color: white; border: none; box-shadow: 0 10px 25px rgba(34, 211, 238, 0.3);`
      : `background: transparent; color: #22d3ee; border: 2px solid #22d3ee;`
    }
  `}
  class={className}
  onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 15px 35px rgba(34, 211, 238, 0.4)';"
  onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='${variant === 'primary' ? '0 10px 25px rgba(34, 211, 238, 0.3)' : 'none'}';"
>
  <slot />
</a>
