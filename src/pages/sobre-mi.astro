---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout 
  title="Sobre Mí | Jonathan Guarirapa - Desarrollador Web"
  description="Conoce más sobre Jonathan Guarirapa, desarrollador web profesional especializado en crear experiencias digitales excepcionales. Mi historia, valores, habilidades y proceso de trabajo."
>
  <!-- Hero Section -->
  <section class="about-hero relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="about-hero-bg absolute inset-0 overflow-hidden" aria-hidden="true">
      <img src="/images/sistemas/idocstore-hero.png" alt="" class="about-hero-img img1" loading="lazy" />
      <img src="/images/sistemas/cotizador-hero.png" alt="" class="about-hero-img img2" loading="lazy" />
      <img src="/images/sistemas/gourmet-arabe-hero.png" alt="" class="about-hero-img img3" loading="lazy" />
      <div class="about-hero-gradient absolute inset-0"></div>
    </div>

    <div class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-full blur-2xl animate-float opacity-20"></div>
    <div class="absolute bottom-20 right-10 w-40 h-40 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full blur-2xl animate-float opacity-15" style="animation-delay: 2s;"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in-left">
          <h1 class="text-5xl md:text-6xl font-bold mb-6">
            <span class="text-black">Sobre</span>

            <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
              Mí
            </span>
          </h1>
          <p class="text-xl text-white mb-8 leading-relaxed">
            Desarrollador web enfocado en sistemas de gestión y automatización, creando soluciones con React y Supabase que optimizan procesos, controlan costos y generan impacto real en negocios.
          </p>
          <br>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href="mailto:jona.develp@gmail.com" size="xl">
              Trabajar juntos
            </Button>
            <Button href="/proyectos-actuales" variant="ghost" size="xl">
              Ver Mis Trabajos
            </Button>
          </div>
        </div>
        
        <div class="animate-fade-in-right">
          <div class="relative">
            <div class="w-80 h-80 mx-auto rounded-full bg-gradient-to-r from-cyan-400 to-blue-500 p-1 animate-pulse-glow">
              <div class="w-full h-full rounded-full overflow-hidden">
                <img 
                  src="/jonadevel.png" 
                  alt="Jonathan Guarirapa - Desarrollador Web"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div class="w-full h-full bg-nextsite-bg-dark flex items-center justify-center" style="display: none;">
                  <span class="text-8xl font-bold text-white">JG</span>
                </div>
              </div>
            </div>
            <!-- Floating Elements -->
            <div class="absolute top-10 -right-10 w-6 h-6 bg-nextsite-accent-blue rounded-full animate-float"></div>
            <div class="absolute bottom-10 -left-10 w-4 h-4 bg-nextsite-light-blue rounded-full animate-float" style="animation-delay: 1s;"></div>
            <div class="absolute top-1/2 -right-20 w-3 h-3 bg-white rounded-full animate-float" style="animation-delay: 2s;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <br>
  <section class="py-20 projects-section">
    <h2 class="text-4xl font-bold text-white mb-8 text-center">
      Proyectos Destacados
    </h2>
  
    <div class="grid md:grid-cols-3 gap-8">
  
      <a href="/projects/muebleria-cotizador" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/sistemas/cotizador-hero.png" alt="Cotizador" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-gray-600 mb-2">Sistema de Cotización</h3>
          <p class="text-gray-600 mb-4">Calculadora de materiales, precios y PDF de cotización en línea.</p>
          <span class="text-white">Ver proyecto →</span>
        </div>
      </a>

      <a href="/projects/sistema-reparaciones" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/sistemas/idocstore-hero.png" alt="Reparaciones" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-white mb-2">Sistema de Gestión de Órdenes</h3>
          <p class="text-gray-600 mb-4">Dashboard técnico y administrador, órdenes, comisiones y reportes.</p>
          <span class="text-white">Ver proyecto →</span>
        </div>
      </a>

      <a href="/projects/gourmet-arabe" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/menuqr/mockup-arabe-Photoroom.png" alt="Gourmet Árabe" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-white mb-2">Gourmet Árabe</h3>
          <p class="text-gray-600 mb-4">Ecommerce de restaurante con menú QR y pedidos online.</p>
          <span class="text-white">Ver proyecto →</span>
        </div>
      </a>

    </div>
  </section>
  <br>
  <!-- Mi Historia -->
  <section id="mi-historia" class="reveal py-20 bg-gradient-to-r from-black-600/10 to-gray-900/10" style="max-width:1100px;margin:0 auto;padding:64px 20px;">
    <h2 class="text-4xl font-bold text-white mb-8 text-center">Mi Historia</h2>
    <div class="space-y-6 text-gray-600 leading-relaxed">
      <p class="text-lg" >
        Me enfoco en construir sistemas que resuelven problemas reales en negocios: 
cotizaciones, control de costos y automatización de procesos.

No solo desarrollo interfaces, sino lógica que permite tomar decisiones y 
evitar pérdidas.

Trabajo con React, Supabase y herramientas modernas para crear soluciones 
rápidas, claras y útiles desde el primer día.
      </p>
    </div>
  </section>

  <!-- Mis Valores -->
  <section id="mis-valores" class="reveal py-16" style="max-width:1100px;margin:0 auto;padding:16px 20px;">
    <h3 class="text-3xl font-bold text-gray-600 mb-8 text-center">Mis Valores</h3>
    <ul class="values space-y-4 ">
      <li class="flex items-start gap-3 text-gray-500 center">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Claridad sin humo</strong> — decisiones explicadas en lenguaje simple.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Detalle y estética</strong> — micro-animaciones, ritmo visual y accesibilidad.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Rendimiento primero</strong> — Core Web Vitals, payload bajo, imágenes optimizadas.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Aprendizaje continuo</strong> — UI moderna, patrones sólidos y buenas prácticas.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">IA con propósito</strong> — automatiza lo repetitivo, mejora UX cuando aporta.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Entrega responsable</strong> — versionado limpio, issues claras y deploy sin sustos.</span>
      </li>
    </ul>
  </section>

  <!-- Mis Habilidades -->
  <section id="mis-habilidades" class="py-20 bg-nextsite-bg-darker" style="max-width:1100px;margin:0 auto;padding:48px 20px;">
    <h2 class="text-4xl font-bold text-white mb-12 text-center">Mis Habilidades</h2>

    <div class="skills-grid">
      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-gray-600 mb-6">Frontend</h4>
        <div class="skill">
          <div class="head"><strong >Astro / React</strong><span>intermedio+</span></div>
          <div class="bar" style="--lvl: 88"></div>
        </div>
        <div class="skill text-gray-600">
          <div class="head text-gray-600"><strong>Tailwind CSS</strong><span>avanzado</span></div>
          <div class="bar" style="--lvl: 92"></div>
        </div>
        <div class="skill">
          <div class="head"><strong>TypeScript</strong><span>intermedio</span></div>
          <div class="bar" style="--lvl: 78"></div>
        </div>
        <div class="skill">
          <div class="head"><strong>UI/UX</strong><span>intermedio+</span></div>
          <div class="bar" style="--lvl: 84"></div>
        </div>
      </article>

      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-white mb-6">Backend</h4>
        <div class="skill"><div class="head"><strong>Node + Express</strong><span>intermedio</span></div><div class="bar" style="--lvl: 80"></div></div>
        <div class="skill"><div class="head"><strong>Prisma / Mongo / SQL</strong><span>básico-intermedio</span></div><div class="bar" style="--lvl: 70"></div></div>
        <div class="skill"><div class="head"><strong>APIs externas</strong><span>intermedio</span></div><div class="bar" style="--lvl: 82"></div></div>
      </article>

      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-white mb-6">Herramientas & IA</h4>
        <div class="skill"><div class="head"><strong>Git/GitHub</strong><span>intermedio+</span></div><div class="bar" style="--lvl: 86"></div></div>
        <div class="skill"><div class="head"><strong>Vercel</strong><span>intermedio</span></div><div class="bar" style="--lvl: 82"></div></div>
        <div class="skill"><div class="head"><strong>Figma</strong><span>intermedio</span></div><div class="bar" style="--lvl: 76"></div></div>
        <div class="skill"><div class="head"><strong>OpenAI/Assistants</strong><span>intermedio</span></div><div class="bar" style="--lvl: 74"></div></div>
      </article>
    </div>
  </section>

  <!-- Cómo Trabajo + CTA -->
  <section id="como-trabajo" class="reveal py-20 bg-nextsite-bg-dark" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
    <h2 class="text-4xl font-bold text-white mb-12 text-center">Cómo Trabajo</h2>
    <ol class="steps text-gray-600">
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Brief de 15 minutos</strong> — llamada o chat.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Wireframe + referencia visual</strong> — Figma.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Prototipo en dev</strong> — previews por PR en Vercel.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">QA de rendimiento + accesibilidad</strong> — CWV y a11y básicos.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Entrega + video corto</strong> — explico el código y el deploy.</li>
    </ol>

    <p class="text-gray-600 text-center mt-12">
      Ideal para negocios que necesitan ordenar procesos o digitalizar operaciones
    </p>
    <div class="cta-row text-center mt-12" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
      <a class="btn" href="mailto:jona.develp@gmail.com">Pídeme una propuesta en 24h</a>
      <a class="btn" href="/projects" style="background:transparent;color:#535455;outline:1px solid #ffffff22">Ver casos con demo</a>
    </div>
  </section>

  <!-- Información Personal -->
  <section class="py-20 bg-nextsite-bg-darker" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-white mb-6">
          Información <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Personal</span>
        </h2>
        <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto mb-8"></div>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 center">
        <div class="card reveal text-center" data-tilt>
          <div class="w-16 h-16 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Ubicación</h3>
          <p class="text-gray-400">Santiago de Chile<br>Buenos Aires<br>Trabajo Remoto</p>
        </div>
        
        <div class="card reveal text-center" data-tilt>
          <div class="w-16 h-16 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Contacto</h3>
          <p class="text-gray-400">
            <a href="mailto:jona.develp@gmail.com" class="text-cyan-400 hover:text-cyan-300 transition-colors">
              jona.develp@gmail.com
            </a>
          </p>
        </div>
        
        <div class="card reveal text-center" data-tilt>
          <div class="w-16 h-16 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Disponibilidad</h3>
          <p class="text-gray-400">Lun - Vie<br>9:00 - 18:00<br>GMT-3 / GMT-5</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-r from-cyan-400/10 to-blue-500/10" style="max-width:1100px;margin:0 auto;padding:32px 20px; ">
    <div class="max-w-4xl mx-auto px-4" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 text-center" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
        ¿Listo para crear algo
        <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
          increíble
        </span>
        juntos?
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto text-center" style="max-width:1100px;margin:0 auto;padding:32px 20px;">

        Si tienes un proyecto en mente o simplemente quieres conversar sobre tecnología, 
        escríbeme. Siempre estoy emocionado por nuevos desafíos.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="mailto:jona.develp@gmail.com" size="lg">
          Hablemos de tu Proyecto
        </Button>
        <Button href="/projects" variant="ghost" size="lg">
          Ver Mi Portafolio
        </Button>
      </div>
    </div>
  </section>
</Layout>

<!-- Scripts de animación -->
<script>
  import { enableTilt } from "../scripts/tilt.js";
  import { revealOnScroll } from "../scripts/reveal.js";
  import { ripple } from "../scripts/ripple.js";
  
  enableTilt(); 
  revealOnScroll(); 
  ripple();
</script>

<style>
  /* Animaciones existentes */
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes fade-in-left {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes fade-in-right {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  .animate-fade-in-left {
    animation: fade-in-left 0.8s ease-out;
  }
  
  .animate-fade-in-right {
    animation: fade-in-right 0.8s ease-out;
  }

  /* Hero background images blur y cards proyectos */
  .about-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .about-hero-img {
    position: absolute;
    width: 120%;
    height: 120%;
    object-fit: cover;
    filter: blur(14px) brightness(0.7) saturate(1.1);
    opacity: 0.55;
    transform-origin: center;
    transition: transform 0.8s ease;
  }
  .about-hero-img.img1 { left: -15%; top: -12%; transform: scale(1.04) rotate(-2deg); }
  .about-hero-img.img2 { right: -15%; top: -8%; transform: scale(1.03) rotate(2deg); }
  .about-hero-img.img3 { left: 12%; bottom: -14%; transform: scale(1.07) rotate(-1deg); }
  .about-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(15,23,42,0.8) 0%, rgba(30,41,59,0.72) 52%, rgba(15,23,42,0.82) 100%);
    z-index: 1;
  }
  .about-hero:hover .about-hero-img.img1 { transform: scale(1.08) rotate(0deg); }
  .about-hero:hover .about-hero-img.img2 { transform: scale(1.06) rotate(1deg); }
  .about-hero:hover .about-hero-img.img3 { transform: scale(1.1) rotate(0deg); }

  .project-card {
    display: block;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.18);
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(15,23,42,0.35);
    transition: transform 0.32s ease, box-shadow 0.32s ease;
    text-decoration: none;
    color: inherit;
    backdrop-filter: blur(10px);
    min-height: auto;
  }
  .project-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(15, 23, 42, 0.35); }
  .project-card-img-wrapper {
    width: 100%;
    aspect-ratio: 3 / 5;
    background: rgba(15, 23, 42, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    max-height: 200px;
  }
  .project-card-img {
    width: auto;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.45s ease;
  }
  .project-card:hover .project-card-img {
    transform: scale(1.05);
  }
  .project-card-body { padding: 0.85rem; }
  .projects-section {
    max-height: 62vh;
    overflow: hidden;
  }
  .projects-section .grid {
    gap: 0.9rem;
  }
  .project-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }
  .project-card p {
    font-size: 0.92rem;
    line-height: 1.35;
  }
  .project-card span {
    font-size: 0.92rem;
  }

  @media (max-width: 1024px) {
    .projects-section {
      max-height: none;
      padding-bottom: 2rem;
    }
    .project-card-img-wrapper {
      max-height: 180px;
      aspect-ratio: 9 / 16;
    }
    .project-card {
      min-height: auto;
    }
  }

  /* Estilos mejorados */
  .card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 16px;
    padding: 18px;
    transition: transform .3s, box-shadow .3s, border-color .3s;
    will-change: transform;
  }
  
  .card:hover {
    box-shadow: 0 10px 40px rgba(0,194,255,.15);
    border-color: rgba(255,255,255,.15);
  }
  
  .reveal {
    opacity: 0;
    transform: translateY(10px) scale(.98);
  }
  
  .reveal.is-in {
    opacity: 1;
    transform: none;
    transition: .55s cubic-bezier(.22,.61,.36,1);
  }
  
  /* Grid de skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3,minmax(0,1fr));
    gap: 22px;
  }
  
  @media (max-width: 980px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .skill {
    margin: 12px 0;
  }
  
  .skill .head {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
    color: #939292;
  }
  
  .skill .bar {
    height: 8px;
    border-radius: 999px;
    background: #2b2f36;
    position: relative;
    overflow: hidden;
  }
  
  .skill .bar::after {
    content: "";
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg,#00E5FF,#7C4DFF);
    width: calc(var(--lvl)*1%);
    animation: grow .9s cubic-bezier(.22,.61,.36,1) forwards;
  }
  
  /* Steps */
  .steps {
    display: grid;
    gap: 10px;
    margin: 8px 0;
    padding: 0 0 0 18px;
  }
  
  .btn {
    position: relative;
    overflow: hidden;
    border: none;
    border-radius: 12px;
    padding: .7rem 1rem;
    font-weight: 700;
    background: linear-gradient(90deg,#00C2FF,#7C4DFF);
    color: #051018;
