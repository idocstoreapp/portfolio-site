---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout 
  title="Sobre Mí | Jonathan Guarirapa - Desarrollador Web"
  description="Conoce más sobre Jonathan Guarirapa, desarrollador web profesional especializado en crear experiencias digitales excepcionales. Mi historia, valores, habilidades y proceso de trabajo."
>
  <!-- Hero Section -->
  <section class="about-hero relative min-h-[78vh] md:min-h-[80vh] flex items-center justify-center overflow-hidden py-12 md:py-0">
    <div class="about-hero-bg absolute inset-0 overflow-hidden" aria-hidden="true">
      <img src="/images/sistemas/idocstore-hero.png" alt="" class="about-hero-img img1" loading="lazy" />
      <img src="/images/sistemas/cotizador-hero.png" alt="" class="about-hero-img img2" loading="lazy" />
      <img src="/images/menuqr/restaurant-arabe.jpeg" alt="" class="about-hero-img img3" loading="lazy" />
      <div class="about-hero-gradient absolute inset-0"></div>
    </div>

    <div class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-full blur-2xl animate-float opacity-20"></div>
    <div class="absolute bottom-20 right-10 w-40 h-40 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full blur-2xl animate-float opacity-15" style="animation-delay: 2s;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 about-hero-content">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="animate-fade-in-left order-1 about-hero-copy">
          <h1 class="max-w-[18ch] text-4xl sm:text-5xl md:text-6xl font-bold mb-5 md:mb-6 text-left">
            <span class="text-gray-100">Sobre</span>

            <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
              Mí
            </span>
          </h1>
          <p class="max-w-[34ch] text-base sm:text-lg md:text-xl text-white mb-6 md:mb-8 leading-relaxed text-left">
            Desarrollador web enfocado en sistemas de gestión y automatización, creando soluciones con React y Supabase que optimizan procesos, controlan costos y generan impacto real en negocios.
          </p>

          <!-- Mobile first: botones compactos y alineados a la izquierda -->
          <div class="flex md:hidden flex-col items-stretch gap-3 w-full max-w-[260px] hero-mobile-ctas">
            <Button href="mailto:jona.develp@gmail.com" size="sm" class="w-full text-center">
              Trabajar juntos
            </Button>
            <Button href="/proyectos-actuales" variant="ghost" size="sm" class="w-full text-center">
              Ver Mis Trabajos
            </Button>
          </div>

          <!-- Desktop mantiene jerarquía visual actual -->
          <div class="hidden md:flex flex-row gap-3 sm:gap-4">
            <Button href="mailto:jona.develp@gmail.com" size="xl">
              Trabajar juntos
            </Button>
            <Button href="/proyectos-actuales" variant="ghost" size="xl" class="hero-btn ghost">
              Ver Mis Trabajos
            </Button>
          </div>
        </div>
        
        <div class="animate-fade-in-right order-2">
          <div class="relative h-[280px] min-[420px]:h-[320px] sm:h-[360px] md:h-[390px] lg:h-[420px] pt-2 md:pt-0">
            <!-- Glow decorativo detrás -->
            <div class="absolute z-0 top-1/2 right-2 sm:right-8 lg:right-1/2 lg:translate-x-1/2 -translate-y-1/2 w-[210px] h-[210px] min-[420px]:w-[230px] min-[420px]:h-[230px] sm:w-[270px] sm:h-[270px] md:w-[320px] md:h-[320px] rounded-full bg-gradient-to-br from-cyan-400/25 via-blue-500/20 to-transparent blur-3xl"></div>

            <!-- Círculo base (sin recortar la imagen) -->
            <div class="absolute z-10 top-1/2 right-3 sm:right-10 lg:right-1/2 lg:translate-x-1/2 -translate-y-1/2 w-[200px] h-[200px] min-[420px]:w-[220px] min-[420px]:h-[220px] sm:w-[260px] sm:h-[260px] md:w-[300px] md:h-[300px] rounded-full bg-slate-950/65 border border-white/10 shadow-[0_30px_90px_rgba(8,47,73,0.35)]"></div>

            <!-- Foto sobresaliendo del círculo -->
            <img 
              src="/jonadevel.jpg" 
              alt="Jonathan Guarirapa - Desarrollador Web"
              class="absolute z-20 top-1/2 right-0 sm:right-6 lg:right-1/2 lg:translate-x-1/2 -translate-y-[52%] w-[235px] h-[235px] min-[420px]:w-[260px] min-[420px]:h-[260px] sm:w-[305px] sm:h-[305px] md:w-[340px] md:h-[340px] lg:w-[360px] lg:h-[360px] max-w-none rounded-full object-cover object-[center_18%] border border-white/20 drop-shadow-[0_26px_30px_rgba(0,0,0,0.45)]"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="absolute z-20 top-1/2 right-0 sm:right-6 lg:right-1/2 lg:translate-x-1/2 -translate-y-[52%] w-[235px] h-[235px] min-[420px]:w-[260px] min-[420px]:h-[260px] sm:w-[305px] sm:h-[305px] md:w-[340px] md:h-[340px] lg:w-[360px] lg:h-[360px] bg-nextsite-bg-dark rounded-full hidden items-center justify-center border border-white/20 drop-shadow-[0_26px_30px_rgba(0,0,0,0.45)]">
              <span class="text-7xl sm:text-8xl font-bold text-white">JG</span>
            </div>

            <!-- Floating Elements -->
            <div class="hidden sm:block absolute z-30 top-10 right-4 lg:right-[15%] w-6 h-6 bg-nextsite-accent-blue rounded-full animate-float"></div>
            <div class="hidden sm:block absolute z-30 bottom-10 right-40 lg:right-[58%] w-4 h-4 bg-nextsite-light-blue rounded-full animate-float" style="animation-delay: 1s;"></div>
            <div class="hidden sm:block absolute z-30 top-1/2 right-0 lg:right-[12%] w-3 h-3 bg-white rounded-full animate-float" style="animation-delay: 2s;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <br>
  <section class="py-14 md:py-20 projects-section">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-8 text-center">
      Proyectos Destacados
    </h2>
  
    <div class="grid md:grid-cols-3 gap-5 md:gap-8">
  
      <a href="/projects/muebleria-cotizador" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/sistemas/cotizador-hero.png" alt="Cotizador" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-gray-600 mb-2">Sistema de Cotización</h3>
          <p class="text-gray-600 mb-4">Calculadora de materiales, precios y PDF de cotización en línea.</p>
          <span class="text-gray-400">Ver proyecto →</span>
        </div>
      </a>

      <a href="/projects/sistema-reparaciones" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/sistemas/idocstore-hero.png" alt="Reparaciones" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-white mb-2">Sistema de Gestión de Órdenes</h3>
          <p class="text-gray-600 mb-4">Dashboard técnico y administrador, órdenes, comisiones y reportes.</p>
          <span class="text-gray-400">Ver proyecto →</span>
        </div>
      </a>

      <a href="/projects/gourmet-arabe" class="project-card" style="text-decoration:none;">
        <div class="project-card-img-wrapper">
          <img src="/images/menuqr/mockup-arabe-Photoroom.png" alt="Gourmet Árabe" class="project-card-img" loading="lazy" />
        </div>
        <div class="project-card-body">
          <h3 class="text-2xl font-bold text-white mb-2">Gourmet Árabe</h3>
          <p class="text-gray-600 mb-4">Ecommerce de restaurante con menú QR y pedidos online.</p>
          <span class="text-gray-400">Ver proyecto →</span>
        </div>
      </a>

    </div>
  </section>
  <br>
  <!-- esxperiencia -->
  <section id="mi-historia" class="reveal py-20 bg-gradient-to-r from-black-600/10 to-gray-900/10" style="max-width:1100px;margin:0 auto;padding:64px 20px;">
    <h2 class="text-4xl font-bold text-white mb-8 text-center">Experiencia Relevante</h2>
    <br>
    <p class="text-gray-400 text-center mb-10">Desglose detallado por proyecto (problema/solución/resultado/stack) con links directos para ver la implementación completa.</p>
    <br>

    <div class="space-y-8 text-gray-300">
      <article class="project-detail-card bg-nextsite-bg-darker border border-white/10 rounded-2xl p-6 shadow-xl text-center" style="background-image: linear-gradient(rgba(3,12,33,.72), rgba(3,12,33,.72)), url('/images/resultados/resultado-impacto-operativo-comercio-tiempo.png'); background-size: cover; background-position: center; background-blend-mode: overlay;">
        <br>
        <h3 class="text-2xl font-bold text-cyan-300 mb-2 ">Sistema de Cotización (Mueblería)</h3>
        <br>
        <p class="text-gray-400 mb-4 text-center">Sistema de cotizaciones para mueblería con generación de PDF, cálculo de materiales, servicios y roles admin/técnico.</p>
        <br>
        <ul class="list-disc pl-5 mb-4 text-gray-300 space-y-1 ">
          <li><strong>Problema:</strong> Gestión manual de cotizaciones y costos, errores en cálculos, sin reportes centralizados.</li>
          <li><strong>Solución:</strong> CRUD de materiales/servicios, cotizador interactivo con cálculos automáticos y PDF.</li>
          <li><strong>Resultado:</strong> reducción de tiempos y errores; cotizaciones profesionales en minutos.</li>
          <li><strong>Stack:</strong> Astro, React, TypeScript, Tailwind CSS, Supabase, React Query, Zod.</li>
        </ul>
        <a href="/projects/muebleria-cotizador" class="inline-block mt-2 px-4 py-2 rounded-lg border border-cyan-400 text-cyan-300  hover:bg-cyan-400/15 justify-center">Ver detalle del proyecto →</a>
      </article>
      <br>
      <article class="project-detail-card bg-nextsite-bg-darker border border-white/10 rounded-2xl p-6 shadow-xl text-center" style="background-image: linear-gradient(rgba(3,12,33,.72), rgba(3,12,33,.72)), url('/images/resultados/resultado-impacto-operativo-servicio-tecnico-tiempo.png'); background-size: cover; background-position: center; background-blend-mode: overlay;">
        <br>
        <h3 class="text-2xl font-bold text-cyan-300 mb-2 text-center">Sistema de Gestión de Órdenes</h3>
        <br>
        <p class="text-gray-400 mb-4">Dashboard de órdenes de reparación con roles diferenciados, cálculo de comisiones y reportes de productividad.</p>
        <br>
        <ul class="list-disc pl-5 mb-4 text-gray-300 space-y-1">
          <li><strong>Problema:</strong> Falta de visibilidad de rendimiento técnico y cálculo manual de comisiones.</li>
          <li><strong>Solución:</strong> dashboards por rol, comisiones automáticas, gestión de órdenes y reportes diarios/mensuales.</li>
          <li><strong>Resultado:</strong> procesos más eficientes, visibilidad 360° y disminución de errores operativos.</li>
          <li><strong>Stack:</strong> Astro, React, TypeScript, Tailwind CSS, Supabase, Vercel.</li>
        </ul>
        <a href="/projects/sistema-reparaciones" class="inline-block mt-2 px-4 py-2 rounded-lg border border-cyan-400 text-cyan-300 hover:bg-cyan-400/15">Ver detalle del proyecto →</a>
      </article>
      <br>
      <article class="project-detail-card bg-nextsite-bg-darker border border-white/10 rounded-2xl p-6 shadow-xl text-center" style="background-image: linear-gradient(rgba(3,12,33,.7), rgba(3,12,33,.7)), url('/images/resultados/resultado-impacto-operativo-restaurante-tiempo.png'); background-size: cover; background-position: center; background-blend-mode: overlay;">
        <br>
        <h3 class="text-2xl font-bold text-cyan-300 mb-2">Gourmet Árabe</h3>
        <br>
        <p class="text-gray-400 mb-4">Solución de pedidos online para restaurante con UX optimizada y catálogo de productos.</p>
        <br>
        <ul class="list-disc pl-5 mb-4 text-gray-300 space-y-1">
          <li><strong>Problema:</strong> Experiencia de compra móvil desordenada y gestión manual de menús.</li>
          <li><strong>Solución:</strong> navegación fluida, visualización de mockups, pedidos online y carrito.</li>
          <li><strong>Resultado:</strong> mayor conversión y experiencia de usuario consistente.</li>
          <li><strong>Stack:</strong> Astro, React, TypeScript, Tailwind CSS, Supabase.</li>
        </ul>
        <a href="/projects/gourmet-arabe" class="inline-block mt-2 px-4 py-2 rounded-lg border border-cyan-400 text-cyan-300 hover:bg-cyan-400/15">Ver detalle del proyecto →</a>
      </article>
      <br>
      <article class="project-detail-card bg-nextsite-bg-darker border border-white/10 rounded-2xl p-6 shadow-xl text-center" style="background-image: linear-gradient(rgba(3,12,33,.7), rgba(3,12,33,.7)), url('/images/resultados/resultado-impacto-operativo-servicios-tiempo.png'); background-size: cover; background-position: center; background-blend-mode: overlay;">
        <br>
        <h3 class="text-2xl font-bold text-cyan-300 mb-2">Kubica Mobiliario</h3>
        <br>
        <p class="text-gray-400 mb-4">Catálogo y gestión de inventario de muebles con filtros y búsqueda avanzada.</p>
        <br>
        <ul class="list-disc pl-5 mb-4 text-gray-300 space-y-1">
          <li><strong>Problema:</strong> inventario difícil de administrar y catálogos poco atractivos.</li>
          <li><strong>Solución:</strong> UI moderna, filtrado, edición rápida y stock en tiempo real.</li>
          <li><strong>Resultado:</strong> reducción de pérdidas y mejora del proceso de venta.</li>
          <li><strong>Stack:</strong> Astro, React, TypeScript, Tailwind CSS, Supabase.</li>
        </ul>
        <a href="/projects/kubica-mobiliario" class="inline-block mt-2 px-4 py-2 rounded-lg border border-cyan-400 text-cyan-300 hover:bg-cyan-400/15">Ver detalle del proyecto →</a>
      </article>
      <br>
      <article class="project-detail-card bg-nextsite-bg-darker border border-white/10 rounded-2xl p-6 shadow-xl text-center" style="background-image: linear-gradient(rgba(3,12,33,.7), rgba(3,12,33,.7)), url('/images/resultados/resultado-impacto-operativo-comercio-crecimiento.png'); background-size: cover; background-position: center; background-blend-mode: overlay;">
        <br>
        <h3 class="text-2xl font-bold text-cyan-300 mb-2">Mueblería Casa Blanca</h3>
        <br>
        <p class="text-gray-400 mb-4">E-commerce con cotizador interno, diseño atractivo y flujo de compra optimizado.</p>
        <br>
        <ul class="list-disc pl-5 mb-4 text-gray-300 space-y-1">
          <li><strong>Problema:</strong> procesos de compra lentos y conversión baja por UX desordenada.</li>
          <li><strong>Solución:</strong> experiencia de compra rápida, cotizador integrado y workflow claro.</li>
          <li><strong>Resultado:</strong> mayor tasa de conversión y menos abandono de carrito.</li>
          <li><strong>Stack:</strong> Astro, React, TypeScript, Tailwind CSS, Supabase.</li>
        </ul>
        <a href="/projects/muebleria-casa-blanca" class="inline-block mt-2 px-4 py-2 rounded-lg border border-cyan-400 text-cyan-300 hover:bg-cyan-400/15">Ver detalle del proyecto →</a>
      </article>
    </div>
  </section>

  </section>

  <!-- Mis Valores -->
  <section id="mis-valores" class="reveal py-16" style="max-width:1100px;margin:0 auto;padding:16px 20px;">
    <h3 class="text-3xl font-bold text-gray-600 mb-8 text-center">Mis Valores</h3>
    <ul class="values space-y-4 ">
      <li class="flex items-start gap-3 text-gray-500 center">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Claridad sin humo</strong> — decisiones explicadas en lenguaje simple.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Detalle y estética</strong> — micro-animaciones, ritmo visual y accesibilidad.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Rendimiento primero</strong> — Core Web Vitals, payload bajo, imágenes optimizadas.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Aprendizaje continuo</strong> — UI moderna, patrones sólidos y buenas prácticas.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">IA con propósito</strong> — automatiza lo repetitivo, mejora UX cuando aporta.</span>
      </li>
      <li class="flex items-start gap-3 text-gray-500">
        <span class="text-cyan-400 font-bold text-lg">•</span>
        <span><strong class="text-gray-600">Entrega responsable</strong> — versionado limpio, issues claras y deploy sin sustos.</span>
      </li>
    </ul>
  </section>

  <!-- Mis Habilidades -->
  <section id="mis-habilidades" class="py-20 bg-nextsite-bg-darker" style="max-width:1100px;margin:0 auto;padding:48px 20px;">
    <h2 class="text-4xl font-bold text-white mb-12 text-center">Mis Habilidades</h2>

    <div class="skills-grid">
      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-gray-600 mb-6">Frontend</h4>
        <div class="skill">
          <div class="head"><strong >Astro / React</strong><span>intermedio+</span></div>
          <div class="bar" style="--lvl: 88"></div>
        </div>
        <div class="skill text-gray-600">
          <div class="head text-gray-600"><strong>Tailwind CSS</strong><span>avanzado</span></div>
          <div class="bar" style="--lvl: 92"></div>
        </div>
        <div class="skill">
          <div class="head"><strong>TypeScript</strong><span>intermedio</span></div>
          <div class="bar" style="--lvl: 78"></div>
        </div>
        <div class="skill">
          <div class="head"><strong>UI/UX</strong><span>intermedio+</span></div>
          <div class="bar" style="--lvl: 84"></div>
        </div>
      </article>

      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-white mb-6">Backend</h4>
        <div class="skill"><div class="head"><strong>Node + Express</strong><span>intermedio</span></div><div class="bar" style="--lvl: 80"></div></div>
        <div class="skill"><div class="head"><strong>Prisma / Mongo / SQL</strong><span>básico-intermedio</span></div><div class="bar" style="--lvl: 70"></div></div>
        <div class="skill"><div class="head"><strong>APIs externas</strong><span>intermedio</span></div><div class="bar" style="--lvl: 82"></div></div>
      </article>

      <article class="card reveal" data-tilt>
        <h4 class="text-2xl font-bold text-white mb-6">Herramientas & IA</h4>
        <div class="skill"><div class="head"><strong>Git/GitHub</strong><span>intermedio+</span></div><div class="bar" style="--lvl: 86"></div></div>
        <div class="skill"><div class="head"><strong>Vercel</strong><span>intermedio</span></div><div class="bar" style="--lvl: 82"></div></div>
        <div class="skill"><div class="head"><strong>Figma</strong><span>intermedio</span></div><div class="bar" style="--lvl: 76"></div></div>
        <div class="skill"><div class="head"><strong>OpenAI/Assistants</strong><span>intermedio</span></div><div class="bar" style="--lvl: 74"></div></div>
      </article>
    </div>
  </section>

  <!-- Cómo Trabajo + CTA -->
  <section id="como-trabajo" class="reveal py-20 bg-nextsite-bg-dark" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
    <h2 class="text-4xl font-bold text-white mb-12 text-center">Cómo Trabajo</h2>
    <ol class="steps text-gray-600">
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Brief de 15 minutos</strong> — llamada o chat.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Wireframe + referencia visual</strong> — Figma.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Prototipo en dev</strong> — previews por PR en Vercel.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">QA de rendimiento + accesibilidad</strong> — CWV y a11y básicos.</li>
      <li class="mb-4 text-lg"><strong class="text-cyan-400">Entrega + video corto</strong> — explico el código y el deploy.</li>
    </ol>

    <p class="text-gray-600 text-center mt-12">
      Ideal para negocios que necesitan ordenar procesos o digitalizar operaciones
    </p>
    <div class="cta-row text-center mt-12" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
      <a class="btn" href="mailto:jona.develp@gmail.com">Pídeme una propuesta en 24h</a>
      <a class="btn" href="/projects" style="background:transparent;color:#535455;outline:1px solid #ffffff22">Ver casos con demo</a>
    </div>
  </section>

  <!-- Información Personal -->
  <section class="py-20 bg-nextsite-bg-darker" style="max-width:1100px;margin:0 auto;padding:32px 20px;">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-white mb-6">
          Información <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Personal</span>
        </h2>
        <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto mb-8"></div>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 center">
        <div class="card reveal text-center" data-tilt>
          <div class="w-16 h-16 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Ubicación</h3>
          <p class="text-gray-400">Santiago de Chile<br>Buenos Aires<br>Trabajo Remoto</p>
